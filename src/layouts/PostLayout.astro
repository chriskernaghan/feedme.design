---
// PostLayout.astro — wraps every blog post.
// Receives frontmatter from the MDX file, plus prev/next from the dynamic route.
import BaseLayout from './BaseLayout.astro';
import PostCTA from '../components/PostCTA.astro';

interface PostNavLink {
  slug: string;
  title: string;
}

interface Props {
  frontmatter: {
    title: string;
    description: string;
    tag: string;
    date: Date;
    readTime: string;
    author: string;
    image?: string;
    imageAlt?: string;
  };
  prev?: PostNavLink | null;
  next?: PostNavLink | null;
}

const { frontmatter, prev, next } = Astro.props;

const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Solo shop, so the author photo is a site-wide asset rather than per-post.
// Drop a square headshot in /public/authors/ and set the path below; until then
// the byline shows a lime initials circle.
const authorAvatar: string | null = null; // e.g. '/authors/chris.jpg'
const authorInitials = 'CK';
---

<BaseLayout title={`${frontmatter.title} — feedme.design`} description={frontmatter.description}>
  <div class="post-hero">
    <div class="post-header-grid">
      <div class="post-header-main">
        <div class="post-header-meta">
          <span class="post-tag">{frontmatter.tag}</span>
          <span class="post-header-date">{formattedDate} · {frontmatter.readTime}</span>
        </div>
        <h1>{frontmatter.title}</h1>
      </div>

      <div class="post-header-aside">
        <p class="post-standfirst">{frontmatter.description}</p>
        <div class="post-byline">
          {authorAvatar ? (
            <img class="post-byline-avatar" src={authorAvatar} alt={frontmatter.author} />
          ) : (
            <div class="post-byline-avatar post-byline-avatar--initials" aria-hidden="true">{authorInitials}</div>
          )}
          <div>
            <div class="post-byline-label">Written by</div>
            <div class="post-byline-name">{frontmatter.author}</div>
          </div>
        </div>
      </div>
    </div>

    {frontmatter.image ? (
      <img
        class="post-hero-image"
        src={frontmatter.image}
        alt={frontmatter.imageAlt ?? frontmatter.title}
        loading="eager"
      />
    ) : (
      <div class="post-hero-image post-hero-image--empty" aria-hidden="true"></div>
    )}
  </div>

  <div class="post-body">
    <slot />
  </div>

  <PostCTA />

  <div class="post-nav">
    {prev ? (
      <a href={`/posts/${prev.slug}`}>← {prev.title}</a>
    ) : (
      <span></span>
    )}
    {next ? (
      <a href={`/posts/${next.slug}`}>{next.title} →</a>
    ) : (
      <a href="/blog">All Posts →</a>
    )}
  </div>
</BaseLayout>
