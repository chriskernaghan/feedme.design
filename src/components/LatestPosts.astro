---
// LatestPosts.astro — homepage blog teaser.
// Pulls the three newest posts from the collection.
// New post published → this section updates itself, no homepage edit needed.
//
// Cards reuse the .post-row styling from the blog index (src/pages/blog.astro)
// so the homepage and blog stay visually consistent. Posts without an image
// fall back to the same tinted placeholder used on the blog page.

import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const latest = allPosts
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);

function formatDate(date: Date): string {
  return new Date(date).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}
---

<section class="latest-posts">
  <div class="posts-inner">
    <div class="posts-header">
      <div>
        <span class="section-label">From the blog</span>
        <h2>Practical WordPress advice</h2>
      </div>
      <a href="/blog" class="view-all-link">View all posts →</a>
    </div>

    <div class="posts-list">
      {latest.map((post) => (
        <a href={`/posts/${post.slug}`} class="post-row">
          {post.data.image ? (
            <img
              src={post.data.image}
              alt={post.data.imageAlt ?? post.data.title}
              class="post-row-thumb"
              loading="lazy"
            />
          ) : (
            <div class="post-row-thumb post-row-thumb--empty" aria-hidden="true"></div>
          )}
          <span class="post-row-tag">{post.data.tag}</span>
          <div class="post-row-title">{post.data.title}</div>
          <div class="post-row-excerpt">{post.data.excerpt ?? post.data.description}</div>
          <div class="post-row-meta">
            <span class="post-row-date">{formatDate(post.data.date)} · {post.data.readTime}</span>
            <span class="post-row-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
