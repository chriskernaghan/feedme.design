---
// FAQLocal.astro — local variant of the FAQ.
// Same markup and classes as FAQ.astro. Questions are rewritten to target
// local search intent (location, meeting in person, areas covered) which is
// one of the stronger on-page signals for local ranking.
const faqs = [
  {
    q: 'Where in Northern Ireland are you based?',
    a: "I'm based in Newtownabbey, just north of Belfast. I work with businesses right across Northern Ireland, from Belfast and Lisburn out to the wider counties. Most of the work happens remotely, but being local means we're on the same hours and I'm never far away.",
    open: true,
  },
  {
    q: 'Do you work with Belfast businesses?',
    a: "Yes, plenty. Belfast firms make up a good chunk of my clients. Whether you're in the city centre, the Titanic Quarter or out in the suburbs, the service is the same, quick responses and someone local who actually knows your site.",
  },
  {
    q: 'Can we meet in person?',
    a: "If it helps, yes. A lot of clients are happy to keep everything over email and phone, but if you'd rather sit down for a coffee to talk through your site, that's easy enough to arrange around Belfast.",
  },
  {
    q: 'How quickly can you start?',
    a: "Usually within a day or two. I'll run a free audit of your site, walk you through what I find, and if we're a good fit, I can start that same week. No onboarding decks, no kickoff meetings, just straight into the work.",
  },
  {
    q: 'What does the monthly retainer actually include?',
    a: "Core, plugin and theme updates, daily backups, uptime monitoring, security scanning and a set number of support hours each month. If something breaks at 9pm on a Tuesday, I'll deal with it. You get a monthly report so you can see exactly what's been done.",
  },
  {
    q: 'Am I locked into a contract?',
    a: "No. It's a rolling monthly arrangement, you can cancel any time. I'd rather keep clients because the work speaks for itself, not because of a contract clause.",
  },
  {
    q: "I'm not very technical, is that a problem?",
    a: "Not at all. Most of my clients aren't. I explain things in plain English and handle everything on the technical side. You just need to tell me what you need, I'll take care of how.",
  },
  {
    q: "How do I get in touch if something's urgent?",
    a: "Email or phone, whichever's easier. Response time is typically under an hour during working hours, and I keep an eye on things outside of them too. You're not going into a ticket queue.",
  },
];
---
<section id="faq" class="faq-section">
  <div class="faq-inner">
    <span class="section-label">Questions</span>
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      {faqs.map((faq) => (
        <details class="faq-item" open={faq.open}>
          <summary class="faq-question">
            <span>{faq.q}</span>
            <span class="faq-icon"></span>
          </summary>
          <div class="faq-answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
