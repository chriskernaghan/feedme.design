---
// Contact.astro — Fillout-embedded audit form.
---

<section id="contact" class="contact-section">
  <div class="contact-inner">
    <div class="contact-header">
      <span class="section-label section-label--light">Get in touch</span>
      <h2>Get your free site audit</h2>
      <p>Tell us about your site and we'll take a look, no obligation, no sales pitch</p>
    </div>
    <div class="fillout-wrapper">
      <div
        style="width:100%;height:500px;"
        data-fillout-id="jYdzYYJ7r9us"
        data-fillout-embed-type="standard"
        data-fillout-inherit-parameters
        data-fillout-dynamic-resize
      ></div>
      <script is:inline src="https://server.fillout.com/embed/v1/"></script>
    </div>
  </div>
</section>
